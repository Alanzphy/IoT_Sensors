# Environment
DEBUG=false

# Database
# DB_HOST: usa 127.0.0.1 en lugar de localhost para evitar problemas
# de conexión vía socket Unix (especialmente en Windows/WSL).
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
# Esta contraseña debe coincidir con MYSQL_ROOT_PASSWORD en docker-compose.yml
# El valor por defecto definido en docker-compose es: rootpass
DB_PASSWORD=rootpass
DB_NAME=sensores_riego

# JWT — CHANGE THESE IN PRODUCTION
SECRET_KEY=CHANGE-ME-generate-a-random-64-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
