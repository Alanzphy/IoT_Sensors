# Environment
DEBUG=false
FRONTEND_PUBLIC_URL=http://localhost:5173

# Database
# DB_HOST: usa 127.0.0.1 en lugar de localhost para evitar problemas
# de conexión vía socket Unix (especialmente en Windows/WSL).
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
# Esta contraseña debe coincidir con MYSQL_ROOT_PASSWORD en docker-compose.yml
# El valor por defecto definido en docker-compose es: rootpass
DB_PASSWORD=rootpass
DB_NAME=sensores_riego

# JWT — CHANGE THESE IN PRODUCTION
SECRET_KEY=CHANGE-ME-generate-a-random-64-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Notifications (Direct backend delivery)
NOTIFICATIONS_ENABLED=false

# Email (SMTP)
NOTIFICATIONS_EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
NOTIFICATION_EMAIL_SUBJECT_PREFIX=[Sensores IoT]

# WhatsApp Cloud API
NOTIFICATIONS_WHATSAPP_ENABLED=false
WHATSAPP_PROVIDER=meta
WHATSAPP_MESSAGE_MODE=text
WHATSAPP_API_BASE_URL=https://graph.facebook.com/v20.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_HTTP_TIMEOUT_SECONDS=15
WHATSAPP_TEMPLATE_NAME=alerta_riego_critica_v1
WHATSAPP_TEMPLATE_LANGUAGE_CODE=es_MX

# WhatsApp via Twilio Content API (set WHATSAPP_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_CONTENT_SID=
TWILIO_STATUS_CALLBACK_URL=
TWILIO_API_BASE_URL=https://api.twilio.com

# AI Reports (Phase 2 backend-first)
AI_REPORTS_ENABLED=false
AI_REPORTS_DEFAULT_NOTIFY=true
AI_REPORTS_SCHEDULER_ENABLED=false
AI_REPORTS_SCHEDULER_POLL_SECONDS=60
AI_REPORTS_SCHEDULE_HOUR_UTC=2
AI_REPORTS_SCHEDULE_MINUTE_UTC=0
AI_REPORTS_HTTP_TIMEOUT_SECONDS=30
AI_REPORTS_SCHEDULER_FORCE=false
AI_ALERT_RECOMMENDATIONS_ENABLED=true
AI_ALERT_RECOMMENDATIONS_MAX_RECENT_READINGS=48

# Azure OpenAI
AZURE_OPENAI_ENABLED=false
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_TEMPERATURE=0.2
AZURE_OPENAI_MAX_TOKENS=900
AZURE_OPENAI_TIMEOUT_SECONDS=30
