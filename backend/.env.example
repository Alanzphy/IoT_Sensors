# Environment
DEBUG=false

# Database
# DB_HOST: usa 127.0.0.1 en lugar de localhost para evitar problemas
# de conexión vía socket Unix (especialmente en Windows/WSL).
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
# Esta contraseña debe coincidir con MYSQL_ROOT_PASSWORD en docker-compose.yml
# El valor por defecto definido en docker-compose es: rootpass
DB_PASSWORD=rootpass
DB_NAME=sensores_riego

# JWT — CHANGE THESE IN PRODUCTION
SECRET_KEY=CHANGE-ME-generate-a-random-64-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Notifications (Direct backend delivery)
NOTIFICATIONS_ENABLED=false

# Email (SMTP)
NOTIFICATIONS_EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
NOTIFICATION_EMAIL_SUBJECT_PREFIX=[Sensores IoT]

# WhatsApp Cloud API
NOTIFICATIONS_WHATSAPP_ENABLED=false
WHATSAPP_API_BASE_URL=https://graph.facebook.com/v20.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_HTTP_TIMEOUT_SECONDS=15
