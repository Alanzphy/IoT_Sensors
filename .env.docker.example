# ===========================================
# Docker Compose Environment Variables
# Copy this file to .env and customize:
#   cp .env.docker.example .env
# ===========================================

# --- Database ---
DB_USER=root
DB_PASSWORD=rootpass
DB_NAME=sensores_riego

# --- JWT (CHANGE IN PRODUCTION!) ---
SECRET_KEY=CHANGE-THIS-TO-A-LONG-RANDOM-STRING
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- App ---
DEBUG=false

# --- Dokploy / Traefik ---
# Tu dominio apuntando a la VPS (usado en las labels de Traefik)
DOMAIN=sensores.alanrz.bond

# --- Inactivity Scan Scheduler ---
# Credenciales de un usuario admin para ejecutar el endpoint programado
SCHEDULER_ADMIN_EMAIL=admin@sensores.com
SCHEDULER_ADMIN_PASSWORD=CHANGE-THIS-PASSWORD

# Frecuencia del escaneo en segundos (300 = cada 5 minutos)
INACTIVITY_SCAN_INTERVAL_SECONDS=300

# Minutos sin datos para considerar nodo inactivo
INACTIVITY_SCAN_MINUTES=20

# Timeout HTTP del scheduler al llamar la API
INACTIVITY_SCAN_HTTP_TIMEOUT_SECONDS=20
